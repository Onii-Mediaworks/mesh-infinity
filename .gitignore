# ============================================
# Mesh Infinity - Unified .gitignore
# ============================================

# Reference and documentation artifacts
reference/

# Build artifacts - all platforms
build/
**/build/
/coverage/

# ============================================
# Rust
# ============================================
target/
**/target/
Cargo.lock

# ============================================
