# ============================================
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/doc/api/
**/ios/Flutter/.last_build_id
frontend/build/

# Flutter generated files
**/Flutter/ephemeral/
**/Flutter/Generated.xcconfig
**/Flutter/flutter_export_environment.sh
**/Flutter/App.framework
**/Flutter/Flutter.framework
**/Flutter/Flutter.podspec
**/Flutter/app.flx
**/Flutter/app.zip
**/Flutter/flutter_assets/
**/Runner/GeneratedPluginRegistrant.*
**/GeneratedPluginRegistrant.java
ServiceDefinitions.json
.flutter-plugins
.flutter-plugins-dependencies
migrate_working_dir/

# Symbolication and obfuscation
app.*.symbols
app.*.map.json

# ============================================
# Android/Gradle
# ============================================
.gradle/
**/.gradle/
gradle-wrapper.jar
/captures/
/gradlew
/gradlew.bat
local.properties
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
.cxx/

# Android keystores (NEVER commit!)
key.properties
**/*.keystore
**/*.jks

