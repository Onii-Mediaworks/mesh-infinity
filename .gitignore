# ============================================
# Mesh Infinity - Unified .gitignore
# ============================================

# ============================================
# Build artifacts
# ============================================
build/
**/build/
/coverage/
reference/

# ============================================
# Rust
# ============================================
target/
**/target/
Cargo.lock
.cargo/

# ============================================
# Flutter / Dart
# ============================================
.dart_tool/
.pub-cache/
.pub/
.flutter-plugins
.flutter-plugins-dependencies
migrate_working_dir/
**/doc/api/

# Flutter generated/ephemeral files
**/Flutter/ephemeral/
**/Flutter/Generated.xcconfig
**/Flutter/flutter_export_environment.sh
**/Flutter/App.framework
**/Flutter/Flutter.framework
**/Flutter/Flutter.podspec
**/Flutter/app.flx
**/Flutter/app.zip
**/Flutter/flutter_assets/
**/Runner/GeneratedPluginRegistrant.*
**/GeneratedPluginRegistrant.java
ServiceDefinitions.json

# Symbolication
app.*.symbols
app.*.map.json

# ============================================
# Android / Gradle
# ============================================
.gradle/
**/.gradle/
gradle-wrapper.jar
/captures/
/gradlew
/gradlew.bat
local.properties
.cxx/
**/android/app/debug/
**/android/app/profile/
**/android/app/release/

# Android keystores (NEVER commit)
key.properties
**/*.keystore
**/*.jks

# ============================================
# iOS / Xcode
# ============================================
**/Pods/
**/xcuserdata/
xcuserdata/
**/.symlinks/
DerivedData/
**/DerivedData/
*.xcworkspace
*.xcuserstate
*.xcscmblueprint
*.mode1v3
*.mode2v3
*.moved-aside
*.pbxuser
*.perspectivev3
**/*sync/
**/.generated/
**/dgph

# Keep default Xcode preference files
!default.mode1v3
!default.mode2v3
!default.pbxuser
!default.perspectivev3

# Flutter-generated iOS plugin registrants
# Regenerated by the Makefile before each Xcode build.
# Committing causes stale plugin lists when pubspec.yaml changes.
platforms/apple/RunnerIOS/GeneratedPluginRegistrant.m
platforms/apple/RunnerIOS/GeneratedPluginRegistrant.h

# ============================================
# macOS
# ============================================
.DS_Store
.swiftpm/
**/.swiftpm/

# ============================================
# Linux
# ============================================
**/linux/flutter/ephemeral/

# ============================================
# Windows
# ============================================
**/windows/flutter/ephemeral/

# Visual Studio
*.suo
*.user
*.userosscache
*.sln.docstates
*.[Cc]ache
!*.[Cc]ache/
x64/
x86/

# ============================================
# IDEs
# ============================================
.idea/
**/.idea/
*.iml
*.ipr
*.iws
.vscode/

# ============================================
# Logs and temp files
# ============================================
*.log
*.class
*.pyc
*.swp
.atom/
.build/
.buildlog/
.build-fails/
.history
.svn/
.sconsign.dblite
.tags*
**/.vagrant/
Icon?
profile

# ============================================
# Node / npm
# ============================================
node_modules/

# ============================================
# Agent / AI tooling (local only, not for contributors)
# ============================================
# .claude/ — Claude Code local state
.claude/
# .codex — Codex agent local configuration
.codex
# .roomodes — Roo/Cline eval tool
.roomodes
# plans/ — agent planning scratchpad
plans/
# .audits/ — local security analysis and agent audit output
.audits/
