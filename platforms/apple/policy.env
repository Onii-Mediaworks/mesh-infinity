#!/usr/bin/env bash
# Canonical Apple policy values (root-level authority).

APPLE_DISPLAY_NAME="Mesh Infinity"
APPLE_BUNDLE_NAME="MeshInfinity"
APPLE_PRODUCT_NAME="meshinfinity"
APPLE_BUNDLE_IDENTIFIER="com.oniimediaworks.meshinfinity"

# Default migration behavior: unsigned builds.
APPLE_SYNC_SIGNING="false"
APPLE_CODE_SIGN_STYLE=""
APPLE_TEAM_ID=""

APPLE_IOS_DEPLOYMENT_TARGET="13.0"
APPLE_MACOS_DEPLOYMENT_TARGET="10.15"

