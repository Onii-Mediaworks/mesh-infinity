import { Button, LineEdit, ScrollView, ListView } from "std-widgets.slint";

export enum NodeMode { Client, Server, Dual }

export struct RoomRow {
    id: string,
    name: string,
    last_message: string,
    unread_count: int,
    unread_label: string,
    timestamp: string,
}

export struct MessageRow {
    id: string,
    sender: string,
    text: string,
    timestamp: string,
    is_outgoing: bool,
}

export struct PeerRow {
    id: string,
    name: string,
    trust_level: int,
    status: string,
}

component SectionHeader {
    in property <string> title;
    Text {
        text: title;
        font-size: 12px;
        font-weight: 600;
        color: #93A1AE;
    }
}

component ActionButton {
    in property <string> label;
    in property <color> background;
    callback clicked();

    Rectangle {
        width: 100%;
        height: 36px;
        background: root.background;
        border-radius: 8px;

        Text {
            text: root.label;
            color: #F0F4F8;
            font-size: 13px;
            x: 12px;
            y: 9px;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.clicked(); }
        }
    }
}

component ToggleRow {
    in property <string> label;
    in-out property <bool> checked;
    in property <bool> enabled: true;
    callback toggled(value: bool);

    Rectangle {
        height: 36px;
        width: 100%;
        background: transparent;

        Text {
            text: label;
            color: #E2E8EF;
            opacity: enabled ? 1.0 : 0.5;
            font-size: 13px;
            x: 0px;
            y: 9px;
        }

        Rectangle {
            width: 44px;
            height: 22px;
            x: parent.width - 44px;
            y: 7px;
            background: checked ? #2A7B6F : #2B333C;
            opacity: enabled ? 1.0 : 0.5;
            border-radius: 11px;

            Rectangle {
                width: 18px;
                height: 18px;
                x: checked ? 22px : 2px;
                y: 2px;
                background: #F0F4F8;
                border-radius: 9px;
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                if (enabled) {
                    toggled(!checked);
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    width: 1200px;
    height: 800px;
    title: "NetInfinity";

    in-out property <[RoomRow]> rooms;
    in-out property <[MessageRow]> messages;
    in-out property <[PeerRow]> peers;
    in-out property <string> active_room_id;
    in-out property <string> active_room_title;
    in-out property <bool> settings_open;
    in-out property <NodeMode> node_mode;
    in-out property <bool> enable_tor;
    in-out property <bool> enable_clearnet;
    in-out property <bool> mesh_discovery;
    in-out property <bool> allow_relays;
    in-out property <string> pairing_code;
    property <bool> client_enabled: root.node_mode != NodeMode.Server;

    callback select_room(room_id: string);
    callback create_room(name: string);
    callback send_message(text: string);
    callback pair_peer(pairing_code: string);
    callback set_node_mode(mode: NodeMode);
    callback set_enable_tor(value: bool);
    callback set_enable_clearnet(value: bool);
    callback set_mesh_discovery(value: bool);
    callback set_allow_relays(value: bool);
    callback toggle_settings();

    property <color> app_background: #0B1015;
    property <color> surface: #141B22;
    property <color> surface_alt: #1D2630;
    property <color> surface_highlight: #222C38;
    property <color> accent: #2A7B6F;
    property <color> accent_soft: #24433F;
    property <color> text_primary: #F0F4F8;
    property <color> text_secondary: #9AA8B5;

    Rectangle {
        width: 100%;
        height: 100%;
        background: root.app_background;

        VerticalLayout {
            width: 100%;
            height: 100%;
            spacing: 0px;

            Rectangle {
                height: 56px;
                horizontal-stretch: 1;
                background: root.surface;

                Text {
                    text: "NetInfinity";
                    font-size: 18px;
                    font-weight: 700;
                    color: root.text_primary;
                    x: 24px;
                    y: 16px;
                }

                Text {
                    text: root.node_mode == NodeMode.Client ? "Client" : (root.node_mode == NodeMode.Server ? "Server" : "Dual");
                    font-size: 12px;
                    color: root.text_secondary;
                    x: 140px;
                    y: 20px;
                }

                ActionButton {
                    x: parent.width - 140px;
                    y: 10px;
                    width: 120px;
                    background: root.accent_soft;
                    label: "Settings";
                    clicked => { root.toggle_settings(); }
                }
            }

            if (root.client_enabled) : HorizontalLayout {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                spacing: 0px;

                Rectangle {
                    width: 320px;
                    vertical-stretch: 1;
                    background: root.surface;

                    VerticalLayout {
                        width: 100%;
                        height: 100%;
                        padding: 20px;
                        spacing: 16px;

                        SectionHeader { title: "Rooms"; }

                        HorizontalLayout {
                            horizontal-stretch: 1;
                            spacing: 8px;

                            room_input := LineEdit {
                                horizontal-stretch: 1;
                                height: 36px;
                                placeholder-text: "Create a room";
                            }

                            ActionButton {
                                width: 90px;
                                background: root.accent;
                                label: "Add";
                                clicked => {
                                    root.create_room(room_input.text);
                                    room_input.text = "";
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            background: root.surface_alt;
                            border-radius: 14px;
                            border-width: 1px;
                            border-color: root.surface_highlight;

                            ListView {
                                width: parent.width;
                                height: parent.height;

                                for room in root.rooms: Rectangle {
                                    width: parent.width - 16px;
                                    height: 68px;
                                    background: root.active_room_id == room.id ? root.surface_highlight : root.surface_alt;
                                    border-radius: 12px;
                                    border-width: 1px;
                                    border-color: root.active_room_id == room.id ? root.accent : root.surface_highlight;
                                    x: 8px;
                                    y: 4px;

                                    Text {
                                        text: room.name;
                                        font-size: 14px;
                                        font-weight: 600;
                                        color: root.text_primary;
                                        x: 14px;
                                        y: 10px;
                                    }

                                    Text {
                                        text: room.last_message;
                                        font-size: 12px;
                                        color: root.text_secondary;
                                        x: 14px;
                                        y: 34px;
                                    }

                                    Text {
                                        text: room.timestamp;
                                        font-size: 11px;
                                        color: root.text_secondary;
                                        x: parent.width - 60px;
                                        y: 12px;
                                    }

                                    if (room.unread_count > 0) : Rectangle {
                                        width: 22px;
                                        height: 22px;
                                        x: parent.width - 34px;
                                        y: 34px;
                                        background: root.accent;
                                        border-radius: 11px;

                                        Text {
                                            text: room.unread_label;
                                            color: #F0F4F8;
                                            font-size: 11px;
                                            font-weight: 700;
                                            horizontal-alignment: center;
                                            vertical-alignment: center;
                                            width: parent.width;
                                            height: parent.height;
                                        }
                                    }

                                    TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        clicked => { root.select_room(room.id); }
                                    }
                                }
                            }

                            if (root.rooms.length == 0) : Text {
                                text: "No rooms yet";
                                color: root.text_secondary;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                Rectangle {
                    width: parent.width - 320px;
                    vertical-stretch: 1;
                    background: root.app_background;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        spacing: 0px;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 60px;
                            background: root.surface;

                            Text {
                                text: root.active_room_title == "" ? "Select a room" : root.active_room_title;
                                color: root.text_primary;
                                font-size: 16px;
                                font-weight: 600;
                                x: 24px;
                                y: 20px;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            vertical-stretch: 1;
                            background: root.app_background;

                            ListView {
                                width: parent.width;
                                height: parent.height;

                                for message in root.messages: Rectangle {
                                    width: parent.width;
                                    height: bubble.height + 12px;
                                    background: transparent;

                                    bubble := Rectangle {
                                        width: parent.width > 640px ? 520px : parent.width - 120px;
                                        height: bubble_content.preferred-height + 24px;
                                        x: message.is_outgoing ? parent.width - bubble.width - 20px : 20px;
                                        y: 6px;
                                        background: message.is_outgoing ? root.accent : root.surface_alt;
                                        border-radius: 14px;

                                        bubble_content := VerticalLayout {
                                            width: parent.width - 24px;
                                            height: self.preferred-height;
                                            x: 12px;
                                            y: 12px;
                                            spacing: 6px;

                                            if (message.is_outgoing == false) : Text {
                                                text: message.sender;
                                                color: #C1CEDA;
                                                font-size: 11px;
                                            }

                                            Text {
                                                text: message.text;
                                                color: root.text_primary;
                                                font-size: 13px;
                                                wrap: word-wrap;
                                                width: parent.width;
                                            }

                                            Text {
                                                text: message.timestamp;
                                                color: message.is_outgoing ? #D1E4E1 : root.text_secondary;
                                                font-size: 10px;
                                            }
                                        }
                                    }
                                }
                            }

                            if (root.active_room_id == "") : Text {
                                text: "Select a room to start chatting.";
                                color: root.text_secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }

                            if (root.active_room_id != "" && root.messages.length == 0) : Text {
                                text: "No messages yet.";
                                color: root.text_secondary;
                                font-size: 14px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 84px;
                            background: root.surface;

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                padding: 16px;
                                spacing: 12px;

                                message_input := LineEdit {
                                    horizontal-stretch: 1;
                                    height: 40px;
                                    placeholder-text: "Type a message";
                                }

                                ActionButton {
                                    width: 120px;
                                    background: root.accent;
                                    label: "Send";
                                    clicked => {
                                        root.send_message(message_input.text);
                                        message_input.text = "";
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if (!root.client_enabled) : Rectangle {
                horizontal-stretch: 1;
                vertical-stretch: 1;
                background: root.app_background;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 32px;
                    spacing: 12px;

                    Text {
                        text: "Server mode active";
                        color: root.text_primary;
                        font-size: 20px;
                        font-weight: 700;
                    }

                    Text {
                        text: "Client UI is disabled in server-only mode.";
                        color: root.text_secondary;
                        font-size: 14px;
                    }

                    Text {
                        text: "Relaunch with --mode client or --mode dual to enable the client UI.";
                        color: root.text_secondary;
                        font-size: 13px;
                    }
                }
            }
        }

        Rectangle {
            visible: root.settings_open;
            width: parent.width;
            height: parent.height;
            background: #00000066;

            settings_panel := Rectangle {
                width: 380px;
                height: parent.height;
                x: parent.width - self.width;
                background: root.surface;

                ScrollView {
                    width: parent.width;
                    height: parent.height;

                    VerticalLayout {
                        width: parent.width;
                        padding: 20px;
                        spacing: 18px;

                        Text {
                            text: "Settings";
                            font-size: 18px;
                            font-weight: 700;
                            color: root.text_primary;
                        }

                    SectionHeader { title: "Server"; }

                    ToggleRow {
                        label: "Enable Server";
                        checked: root.node_mode == NodeMode.Dual;
                        enabled: root.node_mode != NodeMode.Server;
                        toggled(value) => {
                            root.set_node_mode(value ? NodeMode.Dual : NodeMode.Client);
                        }
                    }

                    Text {
                        text: root.node_mode == NodeMode.Dual ? "Server is running alongside the client." : (root.node_mode == NodeMode.Server ? "Server-only mode (client disabled)." : "Client-only mode.");
                        color: root.text_secondary;
                        font-size: 12px;
                    }

                        SectionHeader { title: "Networking"; }

                        ToggleRow {
                            label: "Enable Tor";
                            checked <=> root.enable_tor;
                            toggled(value) => { root.set_enable_tor(value); }
                        }

                        ToggleRow {
                            label: "Enable Clearnet";
                            checked <=> root.enable_clearnet;
                            toggled(value) => { root.set_enable_clearnet(value); }
                        }

                        ToggleRow {
                            label: "Mesh Discovery";
                            checked <=> root.mesh_discovery;
                            toggled(value) => { root.set_mesh_discovery(value); }
                        }

                        ToggleRow {
                            label: "Allow Relays";
                            checked <=> root.allow_relays;
                            toggled(value) => { root.set_allow_relays(value); }
                        }

                        SectionHeader { title: "Trust & Pairing"; }

                        Rectangle {
                            width: 100%;
                            height: 64px;
                            background: root.surface_alt;
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: root.surface_highlight;

                            Text {
                                text: root.pairing_code;
                                font-size: 14px;
                                font-weight: 600;
                                color: root.text_primary;
                                x: 16px;
                                y: 18px;
                            }
                        }

                        HorizontalLayout {
                            width: 100%;
                            spacing: 8px;

                            pairing_input := LineEdit {
                                horizontal-stretch: 1;
                                height: 36px;
                                placeholder-text: "Enter pairing code";
                            }

                            ActionButton {
                                width: 90px;
                                background: root.accent;
                                label: "Pair";
                                clicked => {
                                    root.pair_peer(pairing_input.text);
                                    pairing_input.text = "";
                                }
                            }
                        }

                        Rectangle {
                            width: 100%;
                            height: 260px;
                            background: root.surface_alt;
                            border-radius: 12px;
                            border-width: 1px;
                            border-color: root.surface_highlight;

                            ListView {
                                width: parent.width;
                                height: parent.height;

                            for peer in root.peers: Rectangle {
                                width: parent.width - 16px;
                                height: 52px;
                                background: root.surface_highlight;
                                border-radius: 10px;
                                border-width: 1px;
                                border-color: root.surface_alt;
                                x: 8px;
                                y: 4px;

                                Text {
                                    text: peer.name;
                                    color: root.text_primary;
                                    font-size: 13px;
                                    font-weight: 600;
                                    x: 12px;
                                    y: 10px;
                                }

                                Text {
                                    text: peer.status;
                                    color: root.text_secondary;
                                    font-size: 11px;
                                    x: 12px;
                                    y: 30px;
                                }
                            }
                        }

                            if (root.peers.length == 0) : Text {
                                text: "No trusted peers yet";
                                color: root.text_secondary;
                                font-size: 13px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            TouchArea {
                x: 0px;
                y: 0px;
                width: parent.width - settings_panel.width;
                height: parent.height;
                clicked => { root.toggle_settings(); }
            }
        }
    }
}
